---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Compass from '../art/Compass.astro';
import WordCloud from '../art/WordCloud.astro';
import ScriptDuet from '../art/ScriptDuet.astro';
import CheckGrid from '../art/CheckGrid.astro';
import SoundWave from '../art/SoundWave.astro';
import StreakFlame from '../art/StreakFlame.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const features = [
	{
		id: 'f5',
		idx: '01',
		eyebrow: 'most loved',
		art: 'wave',
		title: t('feat.f5Title'),
		description: t('feat.f5Desc'),
		span: 'md:col-span-8',
		featured: true,
	},
	{
		id: 'f1',
		idx: '02',
		eyebrow: 'foundation',
		art: 'compass',
		title: t('feat.f1Title'),
		description: t('feat.f1Desc'),
		span: 'md:col-span-4',
	},
	{
		id: 'f3',
		idx: '03',
		eyebrow: 'bilingual',
		art: 'duet',
		title: t('feat.f3Title'),
		description: t('feat.f3Desc'),
		span: 'md:col-span-6',
	},
	{
		id: 'f2',
		idx: '04',
		eyebrow: 'lexicon',
		art: 'words',
		title: t('feat.f2Title'),
		description: t('feat.f2Desc'),
		span: 'md:col-span-6',
	},
	{
		id: 'f4',
		idx: '05',
		eyebrow: 'practice',
		art: 'grid',
		title: t('feat.f4Title'),
		description: t('feat.f4Desc'),
		span: 'md:col-span-4',
	},
	{
		id: 'f6',
		idx: '06',
		eyebrow: 'habit',
		art: 'streak',
		title: t('feat.f6Title'),
		description: t('feat.f6Desc'),
		span: 'md:col-span-8',
	},
];
---

<Section id="features" bordered class="bg-paper">
	<Container size="xl">
		<!-- editorial section header -->
		<div class="grid md:grid-cols-12 gap-8 mb-16 md:mb-20 items-end">
			<div class="md:col-span-7" data-reveal="up">
				<div class="text-mono text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
					/ {t('feat.eyebrow')} — chapter 03
				</div>
				<h2 class="mt-6 text-section">
					<span class="block" data-split="word">{t('feat.title')}</span>
				</h2>
			</div>
			<div class="md:col-span-4 md:col-start-9" data-reveal="up" data-reveal-delay="0.15">
				<p class="text-base md:text-lg text-foreground/75 leading-[1.55]">
					{t('feat.subtitle')}
				</p>
				<div class="mt-6 flex items-center gap-2 text-mono text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
					<span>six pillars</span>
					<div class="h-px flex-1 bg-rule"></div>
					<span>scroll</span>
				</div>
			</div>
		</div>

		<!-- Bento grid -->
		<div class="grid md:grid-cols-12 gap-4 md:gap-5">
			{
				features.map((f, i) => (
					<article
						class={`group ${f.span} relative rounded-2xl border border-rule bg-background overflow-hidden transition-colors`}
						data-reveal="up"
						data-reveal-delay={`${i * 0.06}`}
					>
						<div class={`h-full flex flex-col p-6 md:p-8 ${f.featured ? 'md:p-10 min-h-[26rem]' : 'min-h-[22rem]'}`}>
							<!-- Top meta row -->
							<div class="flex items-baseline justify-between">
								<div class="flex items-center gap-3">
									<span class="text-mono text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
										{f.idx}
									</span>
									<div class="h-px w-6 bg-rule"></div>
									<span class={`text-mono text-[10px] uppercase tracking-[0.3em] ${f.featured ? 'text-primary' : 'text-foreground/70'}`}>
										{f.eyebrow}
									</span>
								</div>
							</div>

							<!-- Art -->
							<div class="flex-1 flex items-center justify-center py-8 md:py-10 text-foreground">
								{f.art === 'wave' && <SoundWave class="w-full max-w-md" />}
								{f.art === 'compass' && <Compass class="w-full max-w-xs" />}
								{f.art === 'duet' && <ScriptDuet class="w-full max-w-sm" />}
								{f.art === 'words' && <WordCloud class="w-full max-w-sm" />}
								{f.art === 'grid' && <CheckGrid class="w-full max-w-xs" />}
								{f.art === 'streak' && <StreakFlame class="w-full max-w-md" />}
							</div>

							<!-- Footer -->
							<div class="mt-auto border-t border-rule pt-5 md:pt-6">
								<h3 class={`font-display leading-[1.1] ${f.featured ? 'text-3xl md:text-4xl' : 'text-2xl md:text-3xl'}`}>
									{f.title}
								</h3>
								<p class={`mt-3 text-foreground/70 leading-[1.55] ${f.featured ? 'text-base max-w-xl' : 'text-sm'}`}>
									{f.description}
								</p>
							</div>
						</div>

						<!-- decorative corner accent — small cinnabar dot -->
						<div
							aria-hidden="true"
							class={`absolute top-3 right-3 size-1.5 rounded-full ${f.featured ? 'bg-primary' : 'bg-rule'}`}
						></div>
					</article>
				))
			}
		</div>
	</Container>
</Section>
