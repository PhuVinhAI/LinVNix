---
import Glyph from '../art/Glyph.astro';

interface Props {
	href?: string;
	size?: 'sm' | 'md' | 'lg';
	withText?: boolean;
	class?: string;
}

const {
	href,
	size = 'md',
	withText = true,
	class: className = '',
} = Astro.props;

const iconSizes = {
	sm: 'size-6',
	md: 'size-7',
	lg: 'size-10',
};

const textSizes = {
	sm: 'text-base',
	md: 'text-lg',
	lg: 'text-2xl',
};

const Tag = href ? 'a' : 'div';
---

<Tag href={href} class={`inline-flex items-center gap-2.5 group ${className}`}>
	<Glyph class={`${iconSizes[size]} text-foreground transition-transform duration-700 group-hover:rotate-[-10deg]`} />
	{withText && (
		<span class={`font-display ${textSizes[size]} tracking-tight italic-display font-medium`} style="font-style: italic;">
			Lin<span class="text-primary">·</span>VNix
		</span>
	)}
</Tag>
