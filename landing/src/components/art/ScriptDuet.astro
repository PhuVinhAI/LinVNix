---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
	viewBox="0 0 240 200"
	class={className}
	aria-hidden="true"
>
	<!-- Vietnamese script side -->
	<g font-family="var(--font-display)" font-style="italic">
		<text x="20" y="60" font-size="48" font-weight="500" fill="currentColor">
			Xin
		</text>
		<text x="20" y="105" font-size="48" font-weight="500" fill="var(--primary)">
			chào
		</text>
	</g>

	<!-- divider rule -->
	<line
		x1="20"
		y1="120"
		x2="220"
		y2="120"
		stroke="currentColor"
		stroke-width="0.75"
		opacity="0.4"
		data-draw
	/>

	<!-- Foreign script side (Hello / 你好 / こんにちは hint) -->
	<g font-family="var(--font-sans)" font-size="13" fill="currentColor">
		<text x="20" y="145" letter-spacing="0.15em" opacity="0.6">EN — HELLO</text>
		<text x="20" y="162" letter-spacing="0.15em" opacity="0.5">FR — BONJOUR</text>
		<text x="20" y="179" letter-spacing="0.15em" opacity="0.4">JA — こんにちは</text>
		<text x="20" y="196" letter-spacing="0.15em" opacity="0.3">DE — HALLO</text>
	</g>

	<!-- corner accent -->
	<g stroke="currentColor" stroke-width="1" data-draw>
		<line x1="200" y1="20" x2="220" y2="20" />
		<line x1="220" y1="20" x2="220" y2="40" />
	</g>
	<circle cx="220" cy="40" r="2.5" fill="var(--primary)" />
</svg>
