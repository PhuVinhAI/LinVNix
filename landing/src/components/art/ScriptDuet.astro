---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
	viewBox="0 0 280 200"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- RULE label -->
	<g font-size="9" letter-spacing="0.25em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="22">RULE · QUESTION PARTICLE</text>
	</g>

	<!-- Vietnamese sentence -->
	<g fill="currentColor">
		<text x="14" y="56" font-size="18" font-weight="700" letter-spacing="-0.015em">
			Em uống cà phê
		</text>
		<!-- highlighted "không?" -->
		<rect x="148" y="40" width="56" height="22" rx="4" fill="var(--primary)" opacity="0.12" />
		<text x="155" y="56" font-size="18" font-weight="700" letter-spacing="-0.015em" fill="var(--primary)">
			không?
		</text>
	</g>

	<!-- VI label -->
	<g font-size="8" letter-spacing="0.25em" font-weight="500" fill="currentColor" opacity="0.4">
		<text x="14" y="74">VIETNAMESE</text>
	</g>

	<!-- Arrow connector -->
	<g stroke="currentColor" stroke-width="1" fill="none" opacity="0.4" data-draw>
		<line x1="20" y1="92" x2="20" y2="108" stroke-linecap="round" />
		<path d="M16 104 L20 110 L24 104" stroke-linecap="round" />
	</g>

	<!-- English sentence -->
	<g fill="currentColor">
		<!-- highlighted "Do" -->
		<rect x="11" y="120" width="28" height="22" rx="4" fill="var(--primary)" opacity="0.12" />
		<text x="14" y="136" font-size="18" font-weight="700" letter-spacing="-0.015em" fill="var(--primary)">
			Do
		</text>
		<text x="42" y="136" font-size="18" font-weight="700" letter-spacing="-0.015em">
			you drink coffee?
		</text>
	</g>

	<!-- EN label -->
	<g font-size="8" letter-spacing="0.25em" font-weight="500" fill="currentColor" opacity="0.4">
		<text x="14" y="154">ENGLISH</text>
	</g>

	<!-- Divider -->
	<line x1="14" y1="166" x2="266" y2="166" stroke="currentColor" stroke-width="0.5" opacity="0.25" data-draw />

	<!-- Pattern abstraction -->
	<g font-size="10" font-weight="500" fill="currentColor" opacity="0.6">
		<text x="14" y="184">[S] + [V] + [O] +</text>
		<text x="130" y="184" fill="var(--primary)" font-weight="700">không?</text>
	</g>
</svg>
