---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;

const words = [
	{ t: 'phở', x: 40, y: 50, size: 16, w: 700, italic: false },
	{ t: 'cảm ơn', x: 130, y: 38, size: 11, w: 400, italic: true },
	{ t: 'cái', x: 30, y: 90, size: 9, w: 500, italic: false },
	{ t: 'xin chào', x: 110, y: 95, size: 14, w: 600, italic: true },
	{ t: 'đẹp', x: 60, y: 130, size: 18, w: 700, italic: false, primary: true },
	{ t: 'con', x: 160, y: 140, size: 10, w: 400, italic: false },
	{ t: 'yêu', x: 180, y: 75, size: 13, w: 500, italic: true },
	{ t: 'việt', x: 30, y: 170, size: 11, w: 600, italic: true },
	{ t: 'nói', x: 130, y: 180, size: 12, w: 500, italic: false },
];
---

<svg
	viewBox="0 0 240 200"
	class={className}
	aria-hidden="true"
>
	<!-- decorative connection lines -->
	<g stroke="currentColor" stroke-width="0.5" opacity="0.25" data-draw>
		<line x1="60" y1="50" x2="110" y2="40" />
		<line x1="100" y1="90" x2="60" y2="130" />
		<line x1="180" y1="75" x2="130" y2="40" />
		<line x1="60" y1="130" x2="130" y2="180" />
		<line x1="40" y1="170" x2="100" y2="95" />
	</g>

	<!-- words -->
	<g font-family="var(--font-display)" fill="currentColor">
		{
			words.map((w) => (
				<text
					x={w.x}
					y={w.y}
					font-size={w.size}
					font-weight={w.w}
					font-style={w.italic ? 'italic' : 'normal'}
					fill={w.primary ? 'var(--primary)' : 'currentColor'}
				>
					{w.t}
				</text>
			))
		}
	</g>

	<!-- small dots accent -->
	<g fill="var(--primary)">
		<circle cx="120" cy="68" r="1.5" />
		<circle cx="200" cy="160" r="1.5" />
		<circle cx="35" cy="155" r="1.5" />
	</g>
</svg>
