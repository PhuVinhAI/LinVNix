---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;

const levels = [
	{ code: 'A1', name: 'Beginner',         progress: 1.0,  done: true,  active: false },
	{ code: 'A2', name: 'Elementary',       progress: 1.0,  done: true,  active: false },
	{ code: 'B1', name: 'Intermediate',     progress: 0.55, done: false, active: true  },
	{ code: 'B2', name: 'Upper Inter.',     progress: 0,    done: false, active: false },
	{ code: 'C1', name: 'Advanced',         progress: 0,    done: false, active: false },
	{ code: 'C2', name: 'Mastery',          progress: 0,    done: false, active: false },
];

const rowH = 30;
const barX = 56;
const barW = 130;
---

<svg
	viewBox="0 0 240 240"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- Header -->
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="18">CEFR · KHÓA HỌC</text>
	</g>

	<!-- Vertical timeline rail -->
	<line
		x1="29"
		y1="32"
		x2="29"
		y2={32 + rowH * levels.length}
		stroke="currentColor"
		stroke-width="1"
		opacity="0.18"
		data-draw
	/>

	{
		levels.map((l, i) => {
			const y = 38 + i * rowH;
			return (
				<g>
					{/* CEFR code badge */}
					<text
						x="14"
						y={y + 4}
						font-size="10"
						font-weight="700"
						fill={l.active ? 'var(--primary)' : 'currentColor'}
						opacity={l.done || l.active ? '1' : '0.45'}
						letter-spacing="0.05em"
					>
						{l.code}
					</text>

					{/* Timeline marker */}
					{l.done && (
						<g>
							<circle cx="29" cy={y} r="5" fill="var(--primary)" />
							<path
								d={`M ${26.5} ${y} L ${28.5} ${y + 2} L ${32} ${y - 1.5}`}
								stroke="var(--primary-foreground)"
								stroke-width="1.3"
								fill="none"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</g>
					)}
					{l.active && (
						<>
							<circle cx="29" cy={y} r="6" fill="none" stroke="var(--primary)" stroke-width="1.5">
								<animate attributeName="r" values="6;9;6" dur="2s" repeatCount="indefinite" />
								<animate attributeName="opacity" values="1;0;1" dur="2s" repeatCount="indefinite" />
							</circle>
							<circle cx="29" cy={y} r="4" fill="var(--primary)" />
						</>
					)}
					{!l.done && !l.active && (
						<circle cx="29" cy={y} r="3" fill="none" stroke="currentColor" stroke-width="1" opacity="0.35" />
					)}

					{/* Progress bar */}
					<rect
						x={barX}
						y={y - 2}
						width={barW}
						height="4"
						rx="2"
						fill="currentColor"
						opacity="0.1"
					/>
					{l.progress > 0 && (
						<rect
							x={barX}
							y={y - 2}
							width={barW * l.progress}
							height="4"
							rx="2"
							fill={l.done ? 'currentColor' : 'var(--primary)'}
							opacity={l.done ? '0.85' : '1'}
						/>
					)}

					{/* Level name */}
					<text
						x={barX + barW + 8}
						y={y + 3}
						font-size="8"
						font-weight="500"
						fill="currentColor"
						opacity={l.done || l.active ? '0.9' : '0.5'}
					>
						{l.name}
					</text>

					{/* YOU indicator */}
					{l.active && (
						<g transform={`translate(${barX + barW + 8}, ${y + 13})`}>
							<text
								font-size="7"
								letter-spacing="0.22em"
								font-weight="700"
								fill="var(--primary)"
							>
								◂ YOU
							</text>
						</g>
					)}
				</g>
			);
		})
	}

	<!-- Footer meta -->
	<line
		x1="14"
		y1="218"
		x2="226"
		y2="218"
		stroke="currentColor"
		stroke-width="0.5"
		opacity="0.25"
		data-draw
	/>
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.6">
		<text x="14" y="232">06 LEVELS · 500+ LESSONS</text>
	</g>
	<circle cx="222" cy="229" r="2.5" fill="var(--primary)" />
</svg>
