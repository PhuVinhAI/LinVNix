# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=linvnix

# Application
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Legacy support (deprecated, use JWT_ACCESS_EXPIRES_IN instead)
JWT_EXPIRES_IN=15m

# API
API_PREFIX=api
API_VERSION=v1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Storage
BASE_URL=http://localhost:3000

# Mail Configuration (Gmail)
# Để sử dụng Gmail, bạn cần:
# 1. Bật 2-Step Verification trong Google Account
# 2. Tạo App Password tại: https://myaccount.google.com/apppasswords
# 3. Sử dụng App Password thay vì password thật
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_FROM_NAME=LinVNix
MAIL_FROM_ADDRESS=your-email@gmail.com

# App branding (email templates)
APP_NAME=LinVNix
APP_TAGLINE=Learn Vietnamese, your way

# Frontend URL (admin panel / OAuth redirects)
FRONTEND_URL=http://localhost:3001

# Google OAuth
# Tạo OAuth credentials tại: https://console.cloud.google.com/apis/credentials
# 1. Tạo OAuth 2.0 Client ID
# 2. Thêm Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Default AI provider — used by any feature when AI_<FEATURE>_PROVIDER is not set
GEMINI_API_KEY=your-gemini-api-key
GENAI_API_KEYS=key1,key2,key3          # comma-separated → KeyPool rotate tự động
GENAI_CHAT_MODEL=gemini-2.5-flash
GENAI_CHAT_FALLBACK_MODEL=gemini-2.0-flash
GENAI_EMBED_MODEL=text-embedding-004
GENAI_IMAGE_MODEL=imagen-4.0-generate-001
GENAI_TTS_MODEL=gemini-2.5-flash-preview-tts
GENAI_MAX_RETRIES=2
GENAI_TIMEOUT=30000

# --- Exercise generation (optional OpenAI override) ---
# AI_EXERCISE_PROVIDER=openai           # genai | openai (default: genai)
# AI_EXERCISE_BASE_URL=https://openrouter.ai/api/v1  # base URL của gateway OpenAI-compatible
# AI_EXERCISE_API_KEYS=sk-or-k1,sk-or-k2             # comma-separated → KeyPool riêng cho feature này
# AI_EXERCISE_MODEL=anthropic/claude-3-haiku          # model ID theo gateway
# AI_EXERCISE_FALLBACK_MODEL=                         # optional — thử khi primary model fail (cùng provider)

# --- Simulation AI (optional OpenAI override) ---
# AI_SIMULATION_PROVIDER=openai         # genai | openai (default: genai)
# AI_SIMULATION_BASE_URL=https://openrouter.ai/api/v1
# AI_SIMULATION_API_KEYS=sk-or-k1,sk-or-k2
# AI_SIMULATION_MODEL=openai/gpt-4o-mini
# AI_SIMULATION_FALLBACK_MODEL=

# --- Assistant / Trợ lý AI (optional OpenAI override) ---
# WARNING: Set AI_ASSISTANT_PROVIDER=openai chỉ khi model gateway hỗ trợ tool calling. Nếu không, Trợ lý AI sẽ thành text-only chat (agent loop kết thúc sớm).
# AI_ASSISTANT_PROVIDER=openai          # genai | openai (default: genai)
# AI_ASSISTANT_BASE_URL=http://localhost:11434/v1     # ví dụ: Ollama local
# AI_ASSISTANT_API_KEYS=sk-or-k1                      # key cho gateway; Ollama không cần nhưng vẫn điền placeholder
# AI_ASSISTANT_MODEL=llama3.2                         # model ID theo gateway
# AI_ASSISTANT_FALLBACK_MODEL=
